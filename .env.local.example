# Supabase — supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic — console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Twilio — console.twilio.com → Account Info (top of dashboard)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
# Sandbox number (for testing): +14155238886 | Live: your approved WhatsApp number
TWILIO_WHATSAPP_NUMBER=+14155238886

# Stitch — dashboard.stitch.money → Developers → Credentials
STITCH_CLIENT_ID=your-stitch-client-id
STITCH_CLIENT_SECRET=your-stitch-client-secret

# App
NEXT_PUBLIC_APP_URL=https://getitsorted.co.za
NEXT_PUBLIC_WHATSAPP_NUMBER=+27XXXXXXXXXX

# Cron — any long random string, protects /api/reminders from public access
CRON_SECRET=pick-any-long-random-string-here
